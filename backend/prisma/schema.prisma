generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model marcas{
  id Int @id @default(autoincrement())
  nombre String 
  carros carros []
}

model carros{
  id Int @id @default(autoincrement())
  modelo String 
  fecha_fabricacion DateTime
  disponibilidad Boolean @default(true)
  precio Decimal 
  //atributo de relacion
  marca_id Int
  marca marcas @relation(fields: [marca_id], references: [id])
}

model cursos{
  id Int @id @default(autoincrement())
  nombre String 
  descripcion String 
  precio Decimal 
}

model alumnos{
  id Int @id @default(autoincrement())
  nombre String 
  apellido String
}